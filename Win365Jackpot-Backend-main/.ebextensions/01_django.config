# Runs on every deploy, in order. leader_only steps only run once even if
# this environment is later scaled to multiple instances (avoids every
# instance racing to run migrations at the same time); collectstatic runs
# on every instance since each one serves its own static files via
# Whitenoise. Mirrors what scripts/deploy.sh did on GoDaddy — same steps,
# now run natively by Elastic Beanstalk instead of a cron-job workaround.
container_commands:
  00_ensure_database:
    command: "source /var/app/venv/*/bin/activate && python scripts/ensure_database.py"
    leader_only: true
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python manage.py migrate --noinput"
    leader_only: true
  02_createcachetable:
    command: "source /var/app/venv/*/bin/activate && python manage.py createcachetable"
    leader_only: true
  03_create_default_admins:
    command: "source /var/app/venv/*/bin/activate && python manage.py create_default_admins"
    leader_only: true
  04_collectstatic:
    command: "source /var/app/venv/*/bin/activate && python manage.py collectstatic --noinput"
