# Copy this file to `.env` on the server (cPanel File Manager or SSH) and
# fill in real values. Never commit the real `.env` — it's gitignored.
#
# Generate a secure SECRET_KEY with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=replace-with-output-of-get_random_secret_key
DEBUG=False

# Comma-separated, no spaces — no api. subdomain, everything is one domain
ALLOWED_HOSTS=jackpotsworld.vip,www.jackpotsworld.vip
CORS_ALLOWED_ORIGINS=https://jackpotsworld.vip,https://www.jackpotsworld.vip
CSRF_TRUSTED_ORIGINS=https://jackpotsworld.vip,https://www.jackpotsworld.vip

# Set to True only after confirming HTTPS works via cPanel AutoSSL
SECURE_SSL_REDIRECT=False
# Only set True if your host puts a reverse proxy in front of Passenger
USE_X_FORWARDED_PROTO=False

# HSTS — leave at 0 until SECURE_SSL_REDIRECT/HTTPS is verified working
# (see DEPLOYMENT.md), then set to e.g. 31536000 (1 year). Browsers cache
# this aggressively, so don't turn it on until you're sure.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Absolute path to the built React app's dist/ folder (npm run build).
# Deploy it as a sibling of this Django app's root — see DEPLOYMENT.md.
# Default (if unset) assumes ~/jackpotsworld_frontend_dist next to this app.
FRONTEND_DIST_DIR=/home/cpaneluser/jackpotsworld_frontend_dist

# ── Database (create via cPanel > MySQL Database Wizard) ─────────────────────
# GoDaddy cPanel prefixes DB names/users with your cPanel username, e.g.
# cpaneluser_jackpotdb / cpaneluser_jackpotuser
DB_NAME=cpaneluser_jackpotdb
DB_USER=cpaneluser_jackpotuser
DB_PASSWORD=replace-with-a-strong-password
DB_HOST=localhost
DB_PORT=3306
DB_CONN_MAX_AGE=60
# Only set this when DB_HOST is an AWS RDS endpoint — path to the CA bundle
# this repo ships at certs/global-bundle.pem (downloaded from
# https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem).
# Leave blank for local/GoDaddy MySQL, which don't use this CA chain.
DB_SSL_CA=

# ── Email (Gmail requires a 16-character App Password, not the account password) ─
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=replace-with-sender@gmail.com
EMAIL_HOST_PASSWORD=replace-with-16-char-app-password
DEFAULT_FROM_EMAIL=replace-with-sender@gmail.com

# ── Default admin accounts (seeded by `python manage.py create_default_admins`,
# already wired into scripts/deploy.sh) ───────────────────────────────────────
# Idempotent — only ever creates an account if no user with that email
# exists yet; never touches/resets an existing account's password. Leave an
# *_EMAIL blank to skip seeding that one. Passwords go through Django's
# normal AUTH_PASSWORD_VALIDATORS (min length, not too common, etc.) and are
# stored hashed via set_password() — never in plaintext.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# ── Super Admin IP allowlist (optional) ───────────────────────────────────────
# Comma-separated IPs and/or CIDR ranges, e.g. "203.0.113.5,198.51.100.0/24".
# Leave blank to leave the Super Admin portal unrestricted (default). When
# set, both fresh logins AND already-issued Super Admin tokens are rejected
# from any other IP — see authapp/utils/ip_allowlist.py. Changing this
# requires a Passenger restart, same as ALLOWED_HOSTS.
SUPERADMIN_IP_ALLOWLIST=

# ── Third-party ────────────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=replace-with-real-key

# Optional, comma-separated RSS feed URLs — leave blank to skip
EVENT_RSS_FEEDS=
POKER_RSS_FEEDS=
